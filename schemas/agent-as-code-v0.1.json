{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hummbl-dev/agent-as-code/main/schemas/agent-as-code-v0.1.json",
  "title": "Agent-as-Code v0.1 Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "packetStatus",
    "agentManifest",
    "authority",
    "tools",
    "handoff",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0.1"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["seed", "v0.1-draft", "validated-example", "v0.1-packet"]
    },
    "agentManifest": {
      "type": "object",
      "required": [
        "id",
        "title",
        "version",
        "scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*/[a-z0-9][a-z0-9\\-]*$"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "scope": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["owner", "canActOnBehalfOf"],
      "properties": {
        "owner": {
          "type": "string"
        },
        "canActOnBehalfOf": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind", "scope"],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["tool", "builtin", "human"]
          },
          "scope": {
            "type": "string"
          },
          "timeoutSeconds": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "handoff": {
      "type": "object",
      "required": ["requiresReceipt", "escalationTriggers"],
      "properties": {
        "requiresReceipt": {
          "type": "boolean"
        },
        "escalationTriggers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "receiptRequirements": {
      "type": "object",
      "required": ["review", "runtime", "handoff"],
      "properties": {
        "review": {
          "type": "string",
          "enum": ["required", "optional", "defer-to-adjacent"]
        },
        "runtime": {
          "type": "string"
        },
        "handoff": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "adjacentRepos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
